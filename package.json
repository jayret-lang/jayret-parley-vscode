{
	"name": "jarret-parley",
	"displayName": "Jarret Interactive Editor for VSCode",
	"description": "An interactive editor for the Jarret programming language (Java-flavored Pyret), modeled on jpolitz/pyret-parley-vscode and powered by a forked code.pyret.org build that includes the Jarret translator.",
	"icon": "media/pyret-logo-128.png",
	"version": "0.1.0",
	"publisher": "ulysses4ever",
	"license": "Apache-2.0",
	"engines": {
		"vscode": "^1.74.0"
	},
	"categories": [
		"Other"
	],
	"keywords": [
		"jarret",
		"pyret",
		"dcic",
		"education"
	],
	"activationEvents": [],
	"repository": {
		"type": "git",
		"url": "https://github.com/ulysses4ever/jarret-parley-vscode.git"
	},
	"bugs": {
		"url": "https://github.com/ulysses4ever/jarret-lang/issues"
	},
	"homepage": "https://github.com/ulysses4ever/jarret-lang#readme",
	"files": [
		"dist/web/**/*",
		"media/pyret-logo-128.png",
		"language-configuration.json",
		"syntaxes/jarret.tmLanguage.json"
	],
	"browser": "./dist/web/extension.js",
	"contributes": {
		"languages": [
			{
				"id": "jarret",
				"aliases": [
					"Jarret",
					"jarret"
				],
				"extensions": [
					".jrt"
				],
				"configuration": "./language-configuration.json"
			}
		],
		"grammars": [
			{
				"language": "jarret",
				"scopeName": "source.jrt",
				"path": "./syntaxes/jarret.tmLanguage.json"
			}
		],
		"configurationDefaults": {
			"workbench.editorAssociations": {
				"{git,gitlens,github}:/**/*.{jrt}": "default"
			}
		},
		"menus": {
			"editor/title/run": [
				{
					"command": "jarret-parley.run-file",
					"when": "resourceExtname == .jrt",
					"group": "navigation"
				}
			]
		},
		"commands": [
			{
				"command": "jarret-parley.run-file",
				"title": "Run",
				"category": "Jarret",
				"when": "resourceExtname == .jrt",
				"icon": "$(play)"
			}
		],
		"customEditors": [
			{
				"viewType": "jarret-parley.cpo",
				"displayName": "Jarret code.jarret.org",
				"selector": [
					{
						"filenamePattern": "*.jrt"
					}
				]
			}
		],
		"configuration": {
			"title": "Jarret",
			"properties": {
				"jarret-parley.defaultContext": {
					"type": "string",
					"default": "starter2024",
					"scope": "resource",
					"description": "Controls the starter context used for new Jarret files. The string here appears after `use context` in the file."
				},
				"jarret-parley.urlFileMode": {
					"type": "string",
					"default": "all-remote",
					"scope": "resource",
					"enum": [
						"all-remote",
						"all-local",
						"local-if-present"
					],
					"markdownEnumDescriptions": [
						"Always load `url-file()` imports from the URL",
						"Always load `url-file()` imports from the local filesystem",
						"Load `url-file()` imports from the local filesystem if they exist, otherwise from the URL"
					],
					"description": "Controls how `url-file()` imports are resolved"
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "webpack --mode production"
	},
	"devDependencies": {
		"@types/mustache": "^4.2.5",
		"@types/node": "^18",
		"@types/vscode": "^1.73.0",
		"@typescript-eslint/eslint-plugin": "^7.14.0",
		"@typescript-eslint/parser": "^7.14.0",
		"@vscode/test-web": "^0.0.65",
		"@vscode/vsce": "^3.6.0",
		"copy-webpack-plugin": "^13.0.0",
		"eslint": "^8.26.0",
		"generator-code": "^1.11.5",
		"path-browserify": "^1.0.1",
		"ts-loader": "^9.5.2",
		"typescript": "^5.5.2",
		"vscode-uri": "^3.0.8",
		"webpack": "^5.97.1",
		"webpack-cli": "^6.0.1",
		"yo": "^5.1.0"
	},
	"dependencies": {
		"mustache": "^4.2.0"
	}
}
